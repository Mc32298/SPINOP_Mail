{
  "name": "spinopmailapp",
  "version": "1.0.0",
  "description": "The Private Inbox Command Center",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --windows" 
  },
  "author": "Your Name",
  "license": "ISC",
  "build": {
    "appId": "com.spinop.mail",
    "productName": "Spinop Mail",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/logo.ico"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3"
  }
}